# GeoAI — UI visibility (frontend fetches GET /api/ui-config). Restart backend after edits.
# Set to false / 0 / off to hide menus, dashboard cards, and related controls.

# Object-detection-only demo: leave false. Set true to show each module in the sidebar.
GEOAI_UI_SHOW_SUPER_RESOLUTION=false
GEOAI_UI_SHOW_LULC=false
GEOAI_UI_SHOW_ANALYSIS=false
GEOAI_UI_SHOW_LULC_FIELDS=false
GEOAI_UI_SHOW_DETECTION_THRESHOLD=true
GEOAI_UI_SHOW_CONFIG_PAGE=false

# Used when GEOAI_UI_SHOW_DETECTION_THRESHOLD=false (upload + map display threshold)
GEOAI_DEFAULT_INFERENCE_THRESHOLD=0.3

# --- Esri DLPK-style models (subfolders under models/artifacts/esri/<model_id>/ with .emd + .pth) ---
# BRAEIN_MODELS_ROOT defaults to <repo>/models; Esri models live under <that>/artifacts/esri/
# ESRI_MODELS_ROOT=           # optional absolute path replacing .../artifacts/esri
# ESRI_APPLY_SCALED_NORM_DEFAULT=true   # set false only if an export needs raw stretch without scaled stats
