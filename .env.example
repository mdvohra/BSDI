# Copy to `.env` in this directory — Docker Compose reads it automatically for variable substitution.
#
# Public hostname or address Caddy serves (must match how users open the site in the browser).
PUBLIC_DOMAIN=localhost
#
# Local browsing: open http://localhost (port 80). Port 443 speaks HTTPS only — use https://localhost,
# not http://localhost:443 (that mixes plain HTTP with the HTTPS port and fails).

# Optional: baked into the frontend image at build time. If unset/empty, production uses the browser's
# origin (recommended behind Caddy — works for both http://localhost and https://localhost).
# Only set this if the API lives on a different host than the SPA (e.g. https://api.example.com).
# VITE_API_BASE_URL=https://localhost

# Optional: host port mappings if 80/443 are taken.
# CADDY_HTTP_PORT=8080
# CADDY_HTTPS_PORT=8443
